{
  "expo": {
    "name": "Lifter Protocol",
    "slug": "lifter-protocol",
    "scheme": "lifterprotocol",
    "version": "1.0.8",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a365e8cf-b324-4c60-a8fd-879491e5edd2",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101317"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbitms.lifterprotocol",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.orbitms.lifterprotocol",
      "versionCode": 9,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101317"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-sqlite",
      [
        "./plugins/withVisionCamera",
        {
          "cameraPermissionText": "Lifter Protocol uses the camera to analyse your technique in real time.",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a365e8cf-b324-4c60-a8fd-879491e5edd2"
      }
    },
    "owner": "orbitmss-team"
  }
}
